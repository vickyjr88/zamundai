DB_HOST=agency-db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=agency_db
DB_SYNCHRONIZE=false

REDIS_HOST=agency-redis

# Postgres Docker Variables
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agency_db

TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_POLLING_ENABLED=false
OPENCLAW_API_URL=http://agency-openclaw:18789
OPENCLAW_GATEWAY_TOKEN=replace_with_a_shared_gateway_token
# Optional aliases supported by the API (first non-empty wins):
# OPENCLAW_GATEWAY_TOKEN -> OPENCLAW_GATEWAY_AUTH_TOKEN -> OPENCLAW_API_KEY
OPENCLAW_GATEWAY_AUTH_TOKEN=
OPENCLAW_API_KEY=
OPENCLAW_GATEWAY_IDENTITY_PATH=/app/.openclaw/device.json
OPENCLAW_GATEWAY_TIMEOUT_MS=90000
OPENCLAW_DEFAULT_MODEL=openrouter/auto
OPENCLAW_CONTROL_UI_ALLOWED_ORIGINS_JSON=["http://localhost:18790","http://127.0.0.1:18790"]
PAYSTACK_SECRET_KEY=your_paystack_key
# Optional explicit callback override. Defaults to FRONTEND_URL/dashboard/profile?payment=callback
PAYSTACK_CALLBACK_URL=

BREVO_API_KEY=your_brevo_api_key
MAIL_SENDER_NAME="Zamunda AI"
MAIL_SENDER_EMAIL="noreply@zamunda-ai.com"
JWT_SECRET=your_jwt_secret
FRONTEND_URL=http://localhost:6001

# OpenCLAW / AI
OPENROUTER_API_KEY=your_openrouter_key
GATEWAY_MODE=shared

# UI
NEXT_PUBLIC_API_URL=http://localhost:6100

# API runs on port 6100
PORT=6100
